# Local docker env (do not commit real secrets)
# Copy from .env.docker.example and fill with local values.

# Server
NODE_ENV=development
PORT=3000
SESSION_SECRET=replace-with-local-session-secret
# NOTE: URL userinfo requires percent-encoding for special characters.
DATABASE_URL=postgresql://postgres:replace-with-local-db-password@db:5432/psychpaper
CORS_ORIGIN=http://localhost:8080

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-local-db-password
POSTGRES_DB=psychpaper
