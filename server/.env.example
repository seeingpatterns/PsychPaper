# PostgreSQL 연결. docker-compose.yml의 db 서비스(user/password/db명)와 맞춤.
# Docker로 DB만 띄울 때: docker-compose up -d db → 호스트는 localhost
# 서버도 Docker 안에서 띄우면: 호스트는 db (docker-compose에선 DATABASE_URL=...@db:5432/psychpaper)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/psychpaper
SESSION_SECRET=change-me-in-dev
